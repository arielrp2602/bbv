// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum NoteType {
  CONTADO
  CREDITO
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  CLIP
}

enum Role {
  ADMIN
  EMPLOYEE
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  address       String?
  facebookAlias String?
  phone1        String?
  phone2        String?
  notes         Note[]
  createdAt     DateTime @default(now())
}

model Note {
  id             String     @id @default(cuid())
  items          NoteItem[]
  payments       Payment[]
  type           NoteType
  dueDate        DateTime
  createdAt      DateTime   @default(now())
  subTotal       Decimal
  total          Decimal
  customerId     String
  customer       Customer   @relation(fields: [customerId], references: [id])
  trackingNumber String?
}

model NoteItem {
  id          String   @id @default(cuid())
  description String
  qty         Int
  unitPrice   Decimal
  total       Decimal
  createdAt   DateTime @default(now())

  noteId String
  note   Note   @relation(fields: [noteId], references: [id])
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal
  clipReference String?
  paymentMethod PaymentMethod
  createdAt     DateTime      @default(now())

  noteId String
  note   Note   @relation(fields: [noteId], references: [id])
}
